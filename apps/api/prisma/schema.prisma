// ─────────────────────────────────────────────────────────────────────────────
// Living Platform — Prisma schema
//
// Sprint 1 scope: PLATFORM FOUNDATION ONLY. No business tables (tickets,
// vendors, residents-as-domain, assets, marketplace, …). Everything here is
// the multi-tenant, RBAC, auth and audit substrate that every future Living
// module builds on.
//
// Tenancy model:
//   Tenant 1───N Community          (a Tenant is a customer/org; Communities
//   Tenant 1───N User                are the buildings/associations under it)
//   User   N───N Role  (via UserRole, optionally scoped to a Community)
//   Role   N───N Permission (via RolePermission)  ← permissions are DATA, not code
//
// Platform-level users (Platform Admin) have tenantId = null and a PLATFORM
// scoped role assignment with communityId = null.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum CommunityStatus {
  ONBOARDING
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum UserStatus {
  PENDING // registered, email not yet verified
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

/// Level at which a role assignment applies. Drives how the UserRole.communityId
/// is interpreted and how guards resolve the effective permission set.
enum RoleScope {
  PLATFORM // spans all tenants (Platform Admin)
  TENANT // spans all communities within one tenant (Association Admin)
  COMMUNITY // a single community (Facility Manager, Resident, Vendor)
}

enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ── Sprint 2 — Community Foundation enums ────────────────────────────────────

enum CommunityType {
  APARTMENT
  VILLA
  MIXED
  COMMERCIAL
}

/// Shared lifecycle status for hierarchy nodes and amenities.
enum HierarchyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// The kind of a Block node — keeps the hierarchy flexible across community
/// types (towers for apartments, clusters for villas, blocks for commercial).
enum BlockType {
  TOWER
  VILLA_CLUSTER
  COMMERCIAL_BLOCK
  PLOT
  PODIUM
  OTHER
}

/// Physical occupancy state of a unit.
enum UnitStatus {
  VACANT
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
}

/// How a unit is held. Owner/Resident links arrive with the People engine.
enum OwnershipType {
  OWNER_OCCUPIED
  TENANTED
  VACANT
  UNKNOWN
}

enum DocumentCategory {
  ASSOCIATION
  RULES
  POLICY
  EMERGENCY_CONTACT
  CERTIFICATE
  GOVERNMENT_APPROVAL
  MINUTES_OF_MEETING
  OTHER
}

enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

// ── Sprint 3 — People Foundation enums ───────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum ResidentStatus {
  ACTIVE
  INACTIVE
  MOVED_OUT
}

/// A resident's role on their unit assignment.
enum ResidentRole {
  PRIMARY
  SECONDARY
  OWNER
  TENANT
}

/// Shared active/inactive status for vendors and staff.
enum PersonStatus {
  ACTIVE
  INACTIVE
}

// StaffRole / VendorCategory are no longer enums — staff.role and
// vendor.category are free strings managed per-tenant via CatalogOption.

// ── Sprint 4 — Ticket Engine enums ───────────────────────────────────────────

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketSource {
  RESIDENT_APP
  ADMIN_PORTAL
  INTERNAL
}

/// Structured timeline event types — the engine never stores formatted text.
enum TicketEventType {
  CREATED
  UPDATED
  ASSIGNED
  REASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  RESOLVED
  CLOSED
  REOPENED
  CANCELLED
}

// ── Sprint 5 — Service Request Engine enum (reuses TicketPriority) ────────────

enum ServiceRequestStatus {
  REQUESTED
  ASSIGNED
  ACCEPTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

// ── Sprint 6 — Work Order Engine enums (reuses TicketPriority) ────────────────

enum WorkOrderStatus {
  // Approval lane — a Work Order is APPROVED work. Recommendations enter here;
  // only APPROVED (or an emergency MANUAL) work order reaches the execution lane.
  PENDING_APPROVAL
  APPROVED
  REJECTED
  DRAFT
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  VERIFIED
  CLOSED
  CANCELLED
}

/// Where a Work Order came from. Loose coupling — originId is a plain id with
/// NO foreign key, so any engine (Ticket, Service Request, Preventive
/// Maintenance, future AMC/manual) can create Work Orders without this engine
/// depending on them.
enum WorkOrderOriginType {
  MANUAL
  TICKET
  SERVICE_REQUEST
  PREVENTIVE_MAINTENANCE
  AMC
}

enum WorkOrderEventType {
  CREATED
  RECOMMENDED
  APPROVED
  REJECTED
  ASSIGNED
  REASSIGNED
  ACCEPTED
  STARTED
  PROGRESS_UPDATED
  ON_HOLD
  RESUMED
  COMPLETED
  VERIFIED
  CLOSED
  CANCELLED
}

// ── Asset Foundation (Sprint 7) ──────────────────────────────────────────────

enum AssetStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum AssetCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  FAILED
}

/// Append-only asset history event types. WORK_ORDER_LINKED / SERVICE_REQUEST_LINKED
/// are reserved for when an engine links itself to an asset (forward-compatible).
enum AssetEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  LOCATION_CHANGED
  DOCUMENT_ADDED
  PHOTO_ADDED
  WORK_ORDER_LINKED
  SERVICE_REQUEST_LINKED
  ARCHIVED
}

// ── Preventive Maintenance (Sprint 8) ────────────────────────────────────────

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum MaintenanceRunStatus {
  SCHEDULED
  GENERATED
  SKIPPED
  FAILED
}

// ── AMC Management (Sprint 9) ────────────────────────────────────────────────

enum AMCStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWAL_PENDING
}

enum CoverageType {
  FULL
  PARTIAL
  LABOUR_ONLY
  PARTS_ONLY
  INSPECTION_ONLY
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum AMCEventType {
  CREATED
  UPDATED
  ACTIVATED
  RENEWED
  EXPIRED
  TERMINATED
  ASSET_ADDED
  ASSET_REMOVED
}

// ── Community Operations (Sprint 10) ─────────────────────────────────────────

enum VisitorStatus {
  PENDING
  APPROVED
  CHECKED_IN
  CHECKED_OUT
  REJECTED
}

enum VisitorType {
  GUEST
  DELIVERY
  SERVICE
  CAB
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  EXPIRED
}

// ── Tenancy ──────────────────────────────────────────────────────────────────

model Tenant {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique
  status TenantStatus @default(TRIAL)

  communities Community[]
  users       User[]
  roles       Role[] // tenant-scoped custom roles (system roles have tenantId = null)
  vendors     Vendor[] // vendors are tenant-scoped (cover many communities)

  // Audit / soft-delete base columns (see docs/architecture.md — Audit).
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([status])
  @@map("tenants")
}

model Community {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  code        String // human/admin code, unique within a tenant
  description String?
  type        CommunityType   @default(APARTMENT)
  status      CommunityStatus @default(ONBOARDING)

  // Location
  addressLine1 String?
  addressLine2 String?
  country      String?
  state        String?
  city         String?
  district     String?
  pincode      String?
  latitude     Float?
  longitude    Float?
  timezone     String  @default("Asia/Kolkata")

  // Branding assets (storage keys — resolved via StorageService, never raw URLs)
  logoKey       String?
  coverImageKey String?

  // Contact
  contactEmail      String?
  contactPhone      String?
  website           String?
  /// Array of { name, role, phone } objects.
  emergencyContacts Json?

  // Builder / association
  builderName        String?
  associationName    String?
  registrationNumber String?
  goLiveDate         DateTime?

  /// Free-form future-ready metadata bag.
  metadata Json?

  // Children (Community Foundation)
  userRoles        UserRole[]
  phases           Phase[]
  blocks           Block[]
  floors           Floor[]
  units            Unit[]
  amenities        Amenity[]
  documents        CommunityDocument[]
  settings         CommunitySettings?
  residents        Resident[]
  staff            Staff[]
  tickets          Ticket[]
  serviceRequests  ServiceRequest[]
  workOrders       WorkOrder[]
  assetCategories  AssetCategory[]
  assets           Asset[]
  maintenancePlans MaintenancePlan[]
  amcContracts     AMCContract[]
  visitors         Visitor[]
  amenityBookings  AmenityBooking[]
  announcements    Announcement[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([tenantId, slug])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@map("communities")
}

// ── Identity ─────────────────────────────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  // Null for platform-level users (Platform Admin). Tenant users are scoped here.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email              String     @unique
  /// Login handle for people accounts — the person's mobile number. Unique
  /// across residents/staff/vendors: one phone = one login.
  username           String?    @unique
  emailVerifiedAt    DateTime?
  passwordHash       String
  /// Set on provisioned accounts (common one-time password) — the portal
  /// forces a password change on first login.
  mustChangePassword Boolean    @default(false)
  firstName          String
  lastName           String
  status             UserStatus @default(PENDING)
  lastLoginAt        DateTime?

  roles              UserRole[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  profile            UserProfile?
  // People Foundation — a user represents at most ONE of these (enforced in
  // UserLinkService; each link column is independently unique).
  residentProfile    Resident?
  vendorProfile      Vendor?
  staffProfile       Staff?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([status])
  @@map("users")
}

// ── RBAC (configurable — roles & permissions are rows, never hardcoded) ──────

model Role {
  id       String  @id @default(cuid())
  // Null = system role, available to every tenant. Non-null = tenant custom role.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key         String // e.g. "PLATFORM_ADMIN", "RESIDENT"
  name        String // display name, e.g. "Resident"
  description String?
  scope       RoleScope
  isSystem    Boolean   @default(false) // system roles cannot be deleted/renamed

  permissions RolePermission[]
  userRoles   UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([scope])
  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // canonical "resource:action", e.g. "community:read"
  resource    String // e.g. "community"
  action      String // e.g. "read"
  description String?
  isSystem    Boolean @default(true)

  roles RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// A role granted to a user, optionally scoped to a single community.
/// communityId = null means the assignment applies at the role's own scope
/// (PLATFORM or TENANT). Uniqueness for null-community rows is enforced in the
/// service layer (Postgres treats NULLs as distinct in unique indexes).
model UserRole {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)

  assignedById String?

  createdAt DateTime @default(now())

  @@unique([userId, roleId, communityId])
  @@index([userId])
  @@index([roleId])
  @@index([communityId])
  @@map("user_roles")
}

// ── Auth tokens ──────────────────────────────────────────────────────────────

/// Opaque refresh tokens are stored HASHED. Rotation: each use issues a new
/// token and marks the old one replaced; reuse of an already-rotated token
/// revokes the whole family (theft detection).
model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  familyId  String // shared across a rotation chain
  expiresAt DateTime
  revokedAt DateTime?

  replacedById String?       @unique
  replacedBy   RefreshToken? @relation("TokenRotation", fields: [replacedById], references: [id])
  replaces     RefreshToken? @relation("TokenRotation")

  userAgent String?
  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Single-use, hashed tokens for email verification and password reset.
model VerificationToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       VerificationTokenType
  tokenHash  String                @unique
  expiresAt  DateTime
  consumedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ── Audit trail ──────────────────────────────────────────────────────────────

/// Append-only audit log. actorId/tenantId/communityId are plain ids (no FK
/// relations) so the log survives deletion of the referenced rows and stays
/// cheap to write on the hot path. Join in the reporting layer when needed.
model AuditLog {
  id String @id @default(cuid())

  tenantId    String?
  communityId String?
  actorId     String?
  actorEmail  String?

  action     String // e.g. "auth.login", "user.create"
  resource   String // e.g. "user"
  resourceId String?

  method     String?
  path       String?
  statusCode Int?
  ipAddress  String?
  userAgent  String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([actorId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 2 — Community Foundation
//
// Flexible property hierarchy:  Community → Phase? → Block? → Floor? → Unit
// Every level below Community is OPTIONAL so the same tables model apartments
// (Tower → Floor → Unit), villas (Cluster → Unit, no floor) and commercial
// (Block → Floor → Shop). `communityId` is DENORMALIZED onto every descendant:
// this is a materialized ancestor key (not redundant data) so tenant scoping
// and "everything connects to a community" queries never walk the tree.
// Tenant isolation flows through Community.tenantId.
// ─────────────────────────────────────────────────────────────────────────────

model Phase {
  id          String          @id @default(cuid())
  communityId String
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  sortOrder   Int             @default(0)
  status      HierarchyStatus @default(ACTIVE)
  metadata    Json?

  blocks Block[]
  units  Unit[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, code])
  @@index([communityId])
  @@index([status])
  @@map("phases")
}

model Block {
  id          String          @id @default(cuid())
  communityId String
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  // Optional — a community may have blocks with no phase layer.
  phaseId     String?
  phase       Phase?          @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  name        String
  code        String
  type        BlockType       @default(TOWER)
  totalFloors Int?
  description String?
  sortOrder   Int             @default(0)
  status      HierarchyStatus @default(ACTIVE)
  metadata    Json?

  floors Floor[]
  units  Unit[]
  assets Asset[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, code])
  @@index([communityId])
  @@index([phaseId])
  @@index([status])
  @@map("blocks")
}

model Floor {
  id          String          @id @default(cuid())
  communityId String
  community   Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  blockId     String
  block       Block           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  level       Int // e.g. -1 (basement), 0 (ground), 1, 2 …
  name        String? // display label, e.g. "Ground", "Podium 1"
  description String?
  sortOrder   Int             @default(0)
  status      HierarchyStatus @default(ACTIVE)
  metadata    Json?

  units  Unit[]
  assets Asset[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([blockId, level])
  @@index([communityId])
  @@index([blockId])
  @@map("floors")
}

model Unit {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  // All three ancestors optional — set whichever the community's shape uses.
  phaseId     String?
  phase       Phase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  blockId     String?
  block       Block?    @relation(fields: [blockId], references: [id], onDelete: SetNull)
  floorId     String?
  floor       Floor?    @relation(fields: [floorId], references: [id], onDelete: SetNull)

  unitNumber   String
  type         String? // configurable, e.g. "2BHK", "Studio", "Villa", "Shop"
  carpetArea   Float?
  builtUpArea  Float?
  areaUnit     String        @default("sqft")
  bedrooms     Int?
  bathrooms    Int?
  parkingSlots Int           @default(0)
  status       UnitStatus    @default(VACANT)
  ownership    OwnershipType @default(UNKNOWN)
  // Owner contact (kept on the unit — an owner may not be a resident here).
  ownerName    String?
  ownerPhone   String?
  metadata     Json?

  residentUnits   ResidentUnit[]
  tickets         Ticket[]
  serviceRequests ServiceRequest[]
  workOrders      WorkOrder[]
  assets          Asset[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, unitNumber])
  @@index([communityId])
  @@index([blockId])
  @@index([floorId])
  @@index([status])
  @@map("units")
}

model Amenity {
  id             String          @id @default(cuid())
  communityId    String
  community      Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  category       String? // configurable grouping, e.g. "Sports", "Recreation"
  description    String?
  capacity       Int?
  location       String?
  isBookable     Boolean         @default(false)
  operatingHours Json?
  imageKey       String?
  sortOrder      Int             @default(0)
  status         HierarchyStatus @default(ACTIVE)
  metadata       Json?

  // Booking configuration (Sprint 10 — read by the Amenity Booking engine).
  bookingWindowDays   Int @default(30)
  slotDurationMinutes Int @default(60)

  bookings AmenityBooking[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([communityId])
  @@index([status])
  @@map("amenities")
}

/// One row per community (1:1). Config-heavy, so flexible JSON columns dominate
/// alongside a few typed toggles/colors that the UI binds directly.
model CommunitySettings {
  id          String    @id @default(cuid())
  communityId String    @unique
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  /// { mon: { open, close, closed }, … }
  workingHours       Json?
  maintenanceWindows Json?
  supportContacts    Json?

  // Branding
  primaryColor   String?
  secondaryColor String?

  // Communication channel toggles
  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(false)
  whatsappEnabled Boolean @default(false)
  pushEnabled     Boolean @default(true)

  // Policies (structured, extensible)
  petPolicy     Json?
  parkingPolicy Json?

  /// Escape hatch for tenant-specific settings not yet promoted to columns.
  customSettings Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("community_settings")
}

model CommunityDocument {
  id          String           @id @default(cuid())
  communityId String
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    DocumentCategory @default(OTHER)
  status      DocumentStatus   @default(DRAFT)

  // Storage metadata only — the actual bytes are managed via StorageService.
  // storageKey stays null until a real upload lands (no file uploads this sprint).
  storageKey String?
  fileName   String?
  mimeType   String?
  fileSize   Int?

  version   String?
  issuedOn  DateTime?
  expiresOn DateTime?
  tags      String[]
  metadata  Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([communityId])
  @@index([category])
  @@index([status])
  @@map("community_documents")
}

/// Per-user profile & preferences (1:1 with User).
model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName String?
  avatarKey   String?
  phone       String?
  bio         String?

  language String          @default("en")
  theme    ThemePreference @default(SYSTEM)
  timezone String          @default("Asia/Kolkata")

  /// { channels: { email, sms, push, whatsapp }, categories: { … } }
  notificationPreferences Json?

  // Security preferences (foundation — enforcement arrives with the auth engine)
  twoFactorEnabled Boolean @default(false)

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 3 — People Foundation (Residents, Vendors, Staff)
//
// The minimum people data the Ticket Engine (Sprint 4) needs: who raises a
// ticket (Resident, tied to a Unit), who fulfils it (Staff / Vendor). Each can
// optionally link to a platform User (unique per table; a user maps to at most
// one profile — enforced in UserLinkService) so they can log in without a
// duplicate account. Residents/Staff are community-scoped; Vendors are
// tenant-scoped and cover many communities.
// ─────────────────────────────────────────────────────────────────────────────

model Resident {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  // Optional login link — unique so a user backs at most one resident.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  residentCode String
  firstName    String
  lastName     String
  mobile       String
  email        String?
  photoKey     String?
  gender       Gender?
  dateOfBirth  DateTime?
  occupation   String?

  emergencyContactName         String?
  emergencyContactPhone        String?
  emergencyContactRelationship String?

  moveInDate DateTime?
  status     ResidentStatus @default(ACTIVE)
  notes      String?
  metadata   Json?

  // 1:1 current unit assignment (no historical occupancy this sprint).
  unitAssignment  ResidentUnit?
  tickets         Ticket[]
  serviceRequests ServiceRequest[]
  visitors        Visitor[]
  amenityBookings AmenityBooking[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, residentCode])
  @@index([communityId])
  @@index([status])
  @@index([mobile])
  @@map("residents")
}

/// Maps a Resident to a Unit. One resident → one unit (unique residentId);
/// one unit → many residents. `role` distinguishes primary vs secondary.
model ResidentUnit {
  id         String   @id @default(cuid())
  residentId String   @unique
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  role        ResidentRole   @default(PRIMARY)
  moveInDate  DateTime?
  moveOutDate DateTime?
  status      ResidentStatus @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?

  @@index([unitId])
  @@map("resident_units")
}

model Vendor {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  code              String?
  name              String
  companyName       String?
  // Free strings (admin-managed via CatalogOption), not a hard enum.
  category          String
  serviceCategories String[]
  phone             String
  email             String?
  addressLine       String?
  city              String?
  /// Communities this vendor covers (denormalized ids; vendors span communities).
  communityIds      String[]
  status            PersonStatus @default(ACTIVE)
  remarks           String?
  metadata          Json?

  amcContracts AMCContract[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@map("vendors")
}

model Staff {
  id          String    @id @default(cuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  employeeId String
  firstName  String
  lastName   String
  // Free string (admin-managed via CatalogOption), not a hard enum.
  role       String
  department String?
  phone      String
  email      String?
  photoKey   String?
  status     PersonStatus @default(ACTIVE)
  metadata   Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, employeeId])
  @@index([communityId])
  @@index([role])
  @@index([status])
  @@map("staff")
}

/// Tenant-managed option lists (staff roles, vendor categories, …). Plain
/// tenantId column (AuditLog pattern) — validated in the service, no FK.
model CatalogOption {
  id       String @id @default(cuid())
  tenantId String
  kind     String // 'STAFF_ROLE' | 'VENDOR_CATEGORY'
  name     String

  createdAt   DateTime @default(now())
  createdById String?

  @@unique([tenantId, kind, name])
  @@index([tenantId, kind])
  @@map("catalog_options")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 4 — Ticket Engine (the generic operational core)
//
// A Ticket belongs to exactly one Community and references exactly one Unit and
// one Reporter. Assignment is optional and is Staff XOR Vendor (never both) —
// enforced in the service. The Category carries the business context, so the
// engine stays generic (no plumbing/electrical/etc. logic). Reporter/assignee/
// actor ids are plain columns (the AuditLog pattern) — validated in services,
// not FK-linked, so the engine never reaches back into the People tables.
// ─────────────────────────────────────────────────────────────────────────────

/// Configurable ticket categories. tenantId = null is a SYSTEM default
/// (available to every tenant); non-null is a tenant's own category — the same
/// pattern as system vs. tenant Roles.
model TicketCategory {
  id          String  @id @default(cuid())
  tenantId    String?
  key         String
  name        String
  description String?
  color       String?
  iconKey     String?
  isActive    Boolean @default(true)
  isSystem    Boolean @default(false)
  sortOrder   Int     @default(0)

  tickets Ticket[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("ticket_categories")
}

model Ticket {
  id     String @id @default(cuid())
  /// Monotonic sequence → display number "TKT-000123" (built in the service).
  number Int    @unique @default(autoincrement())

  communityId String
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  unitId      String
  unit        Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)
  categoryId  String
  category    TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  residentId  String?
  resident    Resident?      @relation(fields: [residentId], references: [id], onDelete: SetNull)

  title       String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  source      TicketSource   @default(ADMIN_PORTAL)

  // Reporter + assignee: plain ids (validated in services). Staff XOR Vendor.
  reportedById     String
  assignedStaffId  String?
  assignedVendorId String?
  assignedById     String?
  assignedAt       DateTime?
  reassignedCount  Int       @default(0)

  dueDate      DateTime?
  resolvedDate DateTime?
  closedDate   DateTime?
  notes        String?
  metadata     Json?

  comments    TicketComment[]
  attachments TicketAttachment[]
  timeline    TicketTimeline[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([communityId])
  @@index([unitId])
  @@index([residentId])
  @@index([categoryId])
  @@index([status])
  @@index([priority])
  @@index([assignedStaffId])
  @@index([assignedVendorId])
  @@index([reportedById])
  @@index([createdAt])
  @@map("tickets")
}

model TicketComment {
  id         String  @id @default(cuid())
  ticketId   String
  ticket     Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String // User id (plain)
  body       String
  /// Internal comments are visible only to staff/admin (see TicketCommentService).
  isInternal Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ticketId])
  @@map("ticket_comments")
}

model TicketAttachment {
  id           String @id @default(cuid())
  ticketId     String
  ticket       Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName     String
  contentType  String
  size         Int
  storageKey   String
  uploadedById String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([ticketId])
  @@map("ticket_attachments")
}

/// Append-only, STRUCTURED timeline (never formatted text). The UI renders the
/// sentence from type + actor + reference + metadata.
model TicketTimeline {
  id        String          @id @default(cuid())
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type      TicketEventType
  actorId   String?
  reference String? // related entity id, or "OPEN->ASSIGNED" for status changes
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("ticket_timeline")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 5 — Service Request Engine
//
// A Service Request is requested WORK (resident asks for an electrician, a
// cleaning, …) — NOT an operational issue (that's a Ticket). It is a separate
// engine that may OPTIONALLY link to a Ticket via a nullable scalar `ticketId`
// (no FK, so the Ticket Engine stays independent). Reuses the Ticket Engine's
// patterns: system/tenant catalog, SERIAL number, staff-XOR-vendor assignment,
// status-service-driven workflow, plain actor ids.
// ─────────────────────────────────────────────────────────────────────────────

/// Configurable service catalog. tenantId = null is a seeded system default.
model Service {
  id                       String  @id @default(cuid())
  tenantId                 String?
  key                      String
  name                     String
  description              String?
  estimatedDurationMinutes Int?
  iconKey                  String?
  color                    String?
  isActive                 Boolean @default(true)
  isSystem                 Boolean @default(false)
  sortOrder                Int     @default(0)

  requests ServiceRequest[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("services")
}

model ServiceRequest {
  id     String @id @default(cuid())
  /// Monotonic sequence → display number "SRQ-000123" (built in the service).
  number Int    @unique @default(autoincrement())

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  unitId      String
  unit        Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  serviceId   String
  service     Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  residentId  String?
  resident    Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  title       String
  description String
  priority    TicketPriority       @default(MEDIUM)
  status      ServiceRequestStatus @default(REQUESTED)

  // Requester + assignee: plain ids (validated in services). Staff XOR Vendor.
  requestedById    String
  assignedStaffId  String?
  assignedVendorId String?
  assignedById     String?
  assignedAt       DateTime?
  reassignedCount  Int       @default(0)

  // Scheduling — no calendar engine, no recurrence.
  preferredDate     DateTime?
  preferredTimeSlot String?
  actualStart       DateTime?
  actualEnd         DateTime?

  /// Optional loose link to a Ticket (scalar id — Ticket Engine stays independent).
  ticketId String?

  /// Optional loose reference to an Asset (scalar id — NO FK, Asset Engine stays
  /// independent). Records a SERVICE_REQUEST_LINKED event when set.
  assetId String?

  completedDate DateTime?
  notes         String?
  metadata      Json?

  feedback ServiceFeedback?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([communityId])
  @@index([unitId])
  @@index([residentId])
  @@index([serviceId])
  @@index([status])
  @@index([priority])
  @@index([assignedStaffId])
  @@index([assignedVendorId])
  @@index([ticketId])
  @@index([assetId])
  @@index([createdAt])
  @@map("service_requests")
}

/// Resident feedback, submitted once after completion (1:1 with the request).
model ServiceFeedback {
  id               String         @id @default(cuid())
  serviceRequestId String         @unique
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  rating           Int // 1..5 (validated in the DTO/service)
  comment          String?
  createdById      String

  createdAt DateTime @default(now())

  @@map("service_feedback")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 6 — Work Order Engine (generic execution)
//
// A Work Order is executed WORK assigned to a staff member or vendor. It may
// ORIGINATE from any engine (Ticket, Service Request, future PM/AMC/manual) via
// a loose { originType, originId } pair — NO foreign key — so this engine never
// depends on the origin engines. Reuses the Ticket Engine's patterns (SERIAL
// number, staff-XOR-vendor assignment, status service, structured timeline,
// plain actor ids). Adds progress updates and a verify-before-close gate.
// ─────────────────────────────────────────────────────────────────────────────

model WorkOrder {
  id     String @id @default(cuid())
  /// Monotonic sequence → display number "WO-000001" (built in the service).
  number Int    @unique @default(autoincrement())

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  // Optional — some work is community/common-area wide, not unit-specific.
  unitId      String?
  unit        Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  title       String
  description String
  priority    TicketPriority  @default(MEDIUM)
  status      WorkOrderStatus @default(DRAFT)

  // Assignee: plain ids (validated in the service). Staff XOR Vendor.
  assignedStaffId  String?
  assignedVendorId String?
  assignedById     String?
  assignedAt       DateTime?
  reassignedCount  Int       @default(0)

  // Loose origin link — NO FK to Ticket / ServiceRequest.
  originType WorkOrderOriginType @default(MANUAL)
  originId   String?

  // Approval model — a Work Order is APPROVED work (cost/procurement/major repair).
  // Recommendations start PENDING_APPROVAL; a manager approves → APPROVED (enters
  // execution) or rejects → REJECTED. Manual/emergency work orders skip this.
  requestedById   String?
  requestedDate   DateTime?
  recommendedById String?
  approvedById    String?
  approvedDate    DateTime?
  rejectionReason String?

  // Estimated cost (procurement/budget context). Total is stored (labour + material).
  estimatedLabourCost   Decimal? @db.Decimal(14, 2)
  estimatedMaterialCost Decimal? @db.Decimal(14, 2)
  estimatedTotalCost    Decimal? @db.Decimal(14, 2)

  /// Optional loose reference to an Asset (scalar id — NO FK, Asset Engine stays
  /// independent; assets are never owned by a work order). Populated by whoever
  /// links the asset; the Asset Engine records a WORK_ORDER_LINKED event.
  assetId String?

  estimatedHours Float?
  actualHours    Float?

  dueDate             DateTime?
  startedDate         DateTime?
  completedDate       DateTime?
  verifiedDate        DateTime?
  verifiedById        String?
  verificationRemarks String?

  notes    String?
  metadata Json?

  updates     WorkOrderUpdate[]
  attachments WorkOrderAttachment[]
  timeline    WorkOrderTimeline[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([communityId])
  @@index([unitId])
  @@index([status])
  @@index([priority])
  @@index([assignedStaffId])
  @@index([assignedVendorId])
  @@index([originType, originId])
  @@index([assetId])
  @@index([createdAt])
  @@map("work_orders")
}

model WorkOrderUpdate {
  id              String    @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  authorId        String
  comment         String
  progressPercent Int? // 0..100 (validated in the DTO)
  isInternal      Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([workOrderId])
  @@map("work_order_updates")
}

model WorkOrderAttachment {
  id           String    @id @default(cuid())
  workOrderId  String
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fileName     String
  contentType  String
  size         Int
  storageKey   String
  uploadedById String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([workOrderId])
  @@map("work_order_attachments")
}

/// Append-only, STRUCTURED timeline (never formatted text).
model WorkOrderTimeline {
  id          String             @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  type        WorkOrderEventType
  actorId     String?
  reference   String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([workOrderId])
  @@index([createdAt])
  @@map("work_order_timeline")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 7 — Asset Foundation (independent Asset Engine)
//
// Assets are first-class citizens. Work Orders and Service Requests REFERENCE an
// asset via a loose scalar `assetId` (no FK) — assets are never owned by them.
// The category tree, location (block/floor/unit), documents, photos and an
// append-only event history make this the foundation for future Preventive
// Maintenance, AMC, Inspections, QR tracking, Lifecycle and Predictive
// Maintenance — none of which require refactoring this model. Multi-tenant:
// every row carries tenantId + communityId, verified through CommunityAccessService.
// ─────────────────────────────────────────────────────────────────────────────

/// Community-scoped, self-nesting asset taxonomy (Electrical, HVAC, Lift, …).
model AssetCategory {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  // Self-referencing hierarchy (a category may have a parent + children).
  parentCategoryId String?
  parentCategory   AssetCategory?  @relation("AssetCategoryTree", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories  AssetCategory[] @relation("AssetCategoryTree")

  name        String
  code        String
  icon        String?
  color       String?
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  assets Asset[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([communityId, code])
  @@index([tenantId])
  @@index([communityId])
  @@index([parentCategoryId])
  @@map("asset_categories")
}

model Asset {
  id          String        @id @default(cuid())
  tenantId    String
  communityId String
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  categoryId  String
  category    AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  /// Human/admin identifier, unique within a tenant (e.g. "DG-001").
  assetCode    String
  name         String
  description  String?
  manufacturer String?
  model        String?
  serialNumber String?
  barcode      String?
  qrCode       String?

  // Location — free text + the property hierarchy (all optional; a chiller sits
  // in a block, a DG in the basement, a common asset may have none).
  locationDescription String?
  blockId             String?
  block               Block?  @relation(fields: [blockId], references: [id], onDelete: SetNull)
  floorId             String?
  floor               Floor?  @relation(fields: [floorId], references: [id], onDelete: SetNull)
  unitId              String?
  unit                Unit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)

  // Lifecycle dates
  purchaseDate       DateTime?
  installationDate   DateTime?
  warrantyExpiry     DateTime?
  expectedLifeMonths Int?

  status      AssetStatus      @default(ACTIVE)
  criticality AssetCriticality @default(MEDIUM)
  condition   AssetCondition   @default(GOOD)

  /// Free-form future-ready bag (IoT ids, meter readings, PM config, …).
  metadata Json?

  documents        AssetDocument[]
  photos           AssetPhoto[]
  events           AssetEvent[]
  maintenancePlans MaintenancePlan[]
  amcCoverages     AMCCoverage[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([tenantId, assetCode])
  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([communityId])
  @@index([categoryId])
  @@index([blockId])
  @@index([floorId])
  @@index([unitId])
  @@index([status])
  @@index([criticality])
  @@index([condition])
  @@index([warrantyExpiry])
  @@index([createdAt])
  @@map("assets")
}

model AssetDocument {
  id           String  @id @default(cuid())
  assetId      String
  asset        Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  storageKey   String
  fileName     String
  mimeType     String?
  uploadedById String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([assetId])
  @@map("asset_documents")
}

model AssetPhoto {
  id           String  @id @default(cuid())
  assetId      String
  asset        Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  storageKey   String
  caption      String?
  uploadedById String

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([assetId])
  @@map("asset_photos")
}

/// Immutable, append-only asset history (never formatted text — structured type
/// + optional metadata). The asset's timeline; the same pattern as the engines'
/// structured timelines.
model AssetEvent {
  id            String         @id @default(cuid())
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  eventType     AssetEventType
  description   String?
  performedById String?
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([createdAt])
  @@map("asset_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 8 — Preventive Maintenance Engine (automation layer)
//
// A MaintenancePlan decides WHEN maintenance on an asset is due. It NEVER
// executes: when a plan is due, the scheduler generates a Work Order through the
// existing Work Order Engine (loose originType=PREVENTIVE_MAINTENANCE / originId=
// plan.id — no FK) and records an immutable MaintenanceRun. Execution, workflow,
// assignment, status and timeline all remain in the Work Order Engine.
// ─────────────────────────────────────────────────────────────────────────────

model MaintenancePlan {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  name        String
  description String?

  // Recurrence. cronExpression is used only when frequencyType = CUSTOM.
  frequencyType     MaintenanceFrequency @default(MONTHLY)
  frequencyInterval Int                  @default(1)
  cronExpression    String?

  startDate DateTime
  endDate   DateTime?
  /// The next due instant the scheduler watches. Advanced after each generation.
  nextRunAt DateTime
  lastRunAt DateTime?

  priority                 TicketPriority @default(MEDIUM)
  estimatedDurationMinutes Int?
  requiresVerification     Boolean        @default(false)
  isActive                 Boolean        @default(true)

  checklistTemplates MaintenanceChecklistTemplate[]
  runs               MaintenanceRun[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([communityId])
  @@index([assetId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("maintenance_plans")
}

/// Reusable checklist item on a plan. Snapshotted into each generated Work
/// Order's metadata; checklist EXECUTION is a future sprint.
model MaintenanceChecklistTemplate {
  id           String          @id @default(cuid())
  planId       String
  plan         MaintenancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  title        String
  sortOrder    Int             @default(0)
  isMandatory  Boolean         @default(true)
  instructions String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([planId])
  @@map("maintenance_checklist_templates")
}

/// Immutable execution history: one row per generation attempt. generatedWorkOrderId
/// is a loose scalar (no FK — the Work Order Engine stays independent).
model MaintenanceRun {
  id                   String               @id @default(cuid())
  planId               String
  plan                 MaintenancePlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  scheduledAt          DateTime
  executedAt           DateTime?
  generatedWorkOrderId String?
  status               MaintenanceRunStatus @default(SCHEDULED)
  generationReason     String?
  notes                String?

  createdAt DateTime @default(now())

  @@index([planId])
  @@index([status])
  @@index([createdAt])
  @@map("maintenance_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 9 — AMC Management Engine (contractual layer)
//
// An AMCContract records WHO (vendor) is responsible for maintaining WHICH
// assets (coverage), UNTIL WHEN (dates), under WHAT SLA, at WHAT cost. It does
// NOT execute work (Work Order Engine), does NOT schedule (Preventive
// Maintenance), and does NOT own assets — coverage links to an asset by FK but
// assets remain independent. Multi-tenant: tenantId + communityId on the
// contract, verified through CommunityAccessService.
// ─────────────────────────────────────────────────────────────────────────────

model AMCContract {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  /// Human/admin identifier, unique within a tenant (e.g. "AMC-2026-014").
  contractNumber String
  name           String
  description    String?
  status         AMCStatus @default(DRAFT)

  startDate           DateTime
  endDate             DateTime
  /// Days before endDate at which the contract flips to RENEWAL_PENDING.
  renewalReminderDays Int      @default(30)

  annualCost       Decimal          @db.Decimal(14, 2)
  currency         String           @default("INR")
  paymentFrequency PaymentFrequency @default(YEARLY)

  contactPerson String?
  contactPhone  String?
  contactEmail  String?
  notes         String?
  autoRenew     Boolean @default(false)

  coverages AMCCoverage[]
  slaRules  AMCSLARule[]
  history   AMCHistory[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([communityId])
  @@index([vendorId])
  @@index([status])
  @@index([endDate])
  @@map("amc_contracts")
}

/// Which asset a contract covers, and the coverage terms. One row per
/// (contract, asset) — assets remain independent (FK only, no ownership).
model AMCCoverage {
  id         String      @id @default(cuid())
  contractId String
  contract   AMCContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  assetId    String
  asset      Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)

  coverageType        CoverageType   @default(FULL)
  responseTimeHours   Int?
  resolutionTimeHours Int?
  visitFrequency      String?
  priority            TicketPriority @default(MEDIUM)
  remarks             String?

  createdAt DateTime @default(now())

  @@unique([contractId, assetId])
  @@index([contractId])
  @@index([assetId])
  @@map("amc_coverages")
}

/// Per-priority SLA targets for a contract. One rule per priority.
model AMCSLARule {
  id         String      @id @default(cuid())
  contractId String
  contract   AMCContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  priority               TicketPriority
  responseTimeMinutes    Int
  resolutionTimeMinutes  Int
  escalationAfterMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, priority])
  @@index([contractId])
  @@map("amc_sla_rules")
}

/// Immutable, append-only contract history (structured type + optional metadata).
model AMCHistory {
  id            String       @id @default(cuid())
  contractId    String
  contract      AMCContract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  eventType     AMCEventType
  description   String?
  performedById String?
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([createdAt])
  @@map("amc_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// Sprint 10 — Community Operations (resident-facing community life)
//
// Visitor management, amenity bookings and announcements. Amenities and
// community documents are REUSED from the Community Foundation (Sprint 2) — this
// engine adds no rival models for them. Multi-tenant: tenantId + communityId on
// every row, verified through CommunityAccessService.
// ─────────────────────────────────────────────────────────────────────────────

model Visitor {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  /// The resident hosting the visitor.
  residentId  String
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  visitorName     String
  mobileNumber    String
  vehicleNumber   String?
  visitorType     VisitorType   @default(GUEST)
  purpose         String?
  expectedArrival DateTime
  actualCheckIn   DateTime?
  actualCheckOut  DateTime?
  status          VisitorStatus @default(PENDING)
  /// Unique gate pass code (no QR yet — a short human-readable token).
  passCode        String        @unique
  notes           String?
  approvedById    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([communityId])
  @@index([residentId])
  @@index([status])
  @@index([expectedArrival])
  @@map("visitors")
}

model AmenityBooking {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  amenityId   String
  amenity     Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  residentId  String
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  /// The day of the booking (midnight); startTime/endTime are absolute instants.
  bookingDate DateTime
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(PENDING)
  remarks     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([communityId])
  @@index([amenityId])
  @@index([residentId])
  @@index([status])
  @@index([bookingDate])
  @@map("amenity_bookings")
}

model Announcement {
  id          String    @id @default(cuid())
  tenantId    String
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  title     String
  content   String
  priority  AnnouncementPriority @default(NORMAL)
  publishAt DateTime?
  expiresAt DateTime?
  status    AnnouncementStatus   @default(DRAFT)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([tenantId])
  @@index([communityId])
  @@index([status])
  @@index([priority])
  @@index([publishAt])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification Engine — channel-agnostic delivery tracking
//
// One row per notification the engine handles, across ANY channel (email,
// whatsapp, …): its lifecycle (queued → processing → sent → delivered/read →
// failed → dead-letter), retry count, provider response, duration and
// timestamps. Channels write these via DeliveryTracker; Platform Admin reads
// statistics/history from them. No business logic — a pure delivery audit.
// (Generalized from the former EmailDelivery; existing email rows migrate as
// channel = 'email'.)
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationStatus {
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  READ
  FAILED
  RETRYING
  DEAD_LETTER
}

model NotificationDelivery {
  id String @id @default(cuid())

  // Optional context — set when tied to a tenant/community.
  tenantId    String?
  communityId String?

  channel    String // 'email' | 'whatsapp' | … — the notification channel
  provider   String // 'ses' | 'smtp' | 'meta' — the provider that handled it
  recipients String[] // all primary recipient addresses (emails / phone numbers)
  cc         String[]
  bcc        String[]
  subject    String
  template   String? // template name when sent via a template
  locale     String?
  priority   String? // 'high' | 'normal' | 'low'

  status      NotificationStatus @default(QUEUED)
  retryCount  Int                @default(0)
  maxAttempts Int                @default(5)

  providerMessageId String?
  providerResponse  Json?
  error             String?
  durationMs        Int? // last attempt duration

  queueJobId   String?
  queuedAt     DateTime  @default(now())
  processingAt DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([provider])
  @@index([tenantId])
  @@index([createdAt])
  @@index([queueJobId])
  @@index([providerMessageId])
  @@map("notification_deliveries")
}
