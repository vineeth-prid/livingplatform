# ─────────────────────────────────────────────────────────────
# Living API — application configuration.
# Copy to `.env`:  cp .env.example .env
# Validated at boot by src/config/env.validation.ts — a bad/missing
# required value fails fast with a clear error.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
API_PREFIX=api

# Comma-separated allow-list for CORS (the web app origin(s)).
CORS_ORIGINS=http://localhost:5173
WEB_APP_URL=http://localhost:5173

# Database & cache (match docker-compose defaults).
DATABASE_URL=postgresql://living:living@localhost:5432/living?schema=public
REDIS_URL=redis://localhost:6379

# Auth — REQUIRED. Use long random values (>= 32 chars). Rotate for production.
# Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change-me-dev-access-secret-please-rotate-32+
JWT_REFRESH_SECRET=change-me-dev-refresh-secret-please-rotate-32+
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_REFRESH_TTL_REMEMBER=30d

# Email (local dev points at Mailpit; UI on http://localhost:8025).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Living <no-reply@living.local>

# Rate limiting (window seconds / max requests per window).
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# Storage abstraction (Sprint 2). 'local' is a stub — no real object store is
# wired yet. Add 's3'/'azure'/'gcs' drivers behind the same StorageService.
STORAGE_DRIVER=local
STORAGE_BUCKET=living-local
STORAGE_PUBLIC_URL=http://localhost:4000/storage
STORAGE_SIGNED_URL_TTL=900

# Seed overrides (optional).
# SEED_DEMO_PASSWORD=Living!2024
