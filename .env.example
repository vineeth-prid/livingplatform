# ─────────────────────────────────────────────────────────────
# Living Platform — root infrastructure env (docker-compose).
# Copy to `.env`:  cp .env.example .env
# App-level config lives in apps/api/.env (see apps/api/.env.example).
# ─────────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=living
POSTGRES_PASSWORD=living
POSTGRES_DB=living
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Mailpit (local SMTP catcher)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# pgAdmin (optional, `--profile tools`)
PGADMIN_EMAIL=admin@living.local
PGADMIN_PASSWORD=living
PGADMIN_PORT=5050

# API container (optional, `--profile apps`)
API_PORT=4000
