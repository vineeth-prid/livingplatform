# ── Living web apps (portal / resident / workforce) — production static image ──
# Build context is the repo ROOT. Pass the target app via --build-arg APP=<name>.
#   docker build -f deploy/Dockerfile.web --build-arg APP=portal -t living-portal .
# The built SPA is served by nginx with SPA-fallback, gzip and cache headers.
ARG APP=portal

# 1. Base with pnpm via corepack.
FROM node:20-alpine AS base
RUN corepack enable
WORKDIR /repo

# 2. Install the full workspace (frontend builds need the shared packages).
FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps ./apps
COPY packages ./packages
COPY tsconfig.base.json ./
RUN pnpm install --frozen-lockfile

# 3. Build the requested app (Vite → static dist/).
#    VITE_API_BASE_URL is baked into the bundle at build time.
FROM deps AS build
ARG APP
ARG VITE_API_BASE_URL=http://localhost:4000/api/v1
ENV NODE_ENV=production
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN pnpm --filter @living/${APP} build

# 4. Runtime — nginx serving the static build.
FROM nginx:1.27-alpine AS runtime
ARG APP
# Non-root, minimal. Health file for container checks.
COPY deploy/nginx/spa.conf /etc/nginx/conf.d/default.conf
COPY --from=build /repo/apps/${APP}/dist /usr/share/nginx/html
RUN printf 'ok' > /usr/share/nginx/html/healthz
EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD wget -qO- http://127.0.0.1:8080/healthz || exit 1
